{
  "servers": {
    "ryan-mcp-local-direct": {
      "type": "http",
      "url": "http://localhost:8081/mcp"
    },
    "bifrost-gateway-local": {
      "type": "http",
      "url": "http://localhost:8080/mcp",
      "headers": {
        "Authorization": "Bearer $BIFROST_LOCAL_VK",
        "x-bf-vk": "$BIFROST_LOCAL_VK"
      }
    },
    "aspire": {
      "type": "stdio",
      "command": "aspire",
      "args": [
        "agent",
        "mcp"
      ]
    }
  }
}