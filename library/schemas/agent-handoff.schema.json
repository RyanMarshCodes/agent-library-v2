{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-stack.local/schemas/agent-handoff.schema.json",
  "title": "AgentHandoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fromRole",
    "toRole",
    "task",
    "inputs",
    "successCriteria"
  ],
  "properties": {
    "fromRole": {
      "type": "string",
      "minLength": 1
    },
    "toRole": {
      "type": "string",
      "minLength": 1
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "successCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
