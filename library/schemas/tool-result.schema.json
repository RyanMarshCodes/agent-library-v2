{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-stack.local/schemas/tool-result.schema.json",
  "title": "ToolResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tool",
    "status",
    "timestampUtc"
  ],
  "properties": {
    "tool": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "warning",
        "error"
      ]
    },
    "timestampUtc": {
      "type": "string",
      "format": "date-time"
    },
    "durationMs": {
      "type": "integer",
      "minimum": 0
    },
    "summary": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data": {
      "type": [
        "object",
        "array",
        "string",
        "number",
        "boolean",
        "null"
      ]
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    }
  }
}
