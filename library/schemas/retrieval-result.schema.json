{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-stack.local/schemas/retrieval-result.schema.json",
  "title": "RetrievalResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "query",
    "results"
  ],
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "score",
          "snippet"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "snippet": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "citations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "truncated": {
      "type": "boolean"
    }
  }
}
