{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-stack.local/schemas/memory-record.schema.json",
  "title": "MemoryRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "scope",
    "kind",
    "content",
    "createdUtc"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "enum": [
        "user",
        "repo",
        "session"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "decision",
        "pattern",
        "constraint",
        "fact",
        "preference"
      ]
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "expiresUtc": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "createdUtc": {
      "type": "string",
      "format": "date-time"
    },
    "updatedUtc": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "source": {
      "type": "string"
    }
  }
}
