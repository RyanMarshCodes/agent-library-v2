{
  "McpOptions": {
    "Knowledge": {
      "OfficialPath": "../../../knowledge/global",
      "OrganizationPath": "../../../knowledge/backend",
      "ProjectPath": "../../../knowledge/frontend",
      "IndexPath": "../../../.local/mcp-index"
    },
    "Ingestion": {
      "AutoIngestOnStartup": true,
      "WatchForChanges": true,
      "DebounceMilliseconds": 1000
    },
    "Agents": {
      "LocalPath": "../../../.local/agents",
      "LibraryPath": "../../../agents",
      "ProjectPath": null
    },
    "WorkflowState": {
      "Provider": "postgres"
    },
    "ExecutePolicy": {
      "EnforceAllowlist": true
    },
    "RoutingBudget": {
      "EnforcePerWorkflowBudget": true,
      "DefaultWorkflowBudgetUsd": 1.0
    },
    "RoutingPolicy": {
      "EnforceSmallFirst": true,
      "EscalateAtEstimatedTotalTokens": 6000,
      "EnableBudgetFallback": true
    },
    "Retrieval": {
      "MaxKnowledgeResults": 20,
      "MaxSnippetChars": 220,
      "EnableSemanticCache": true,
      "SemanticCacheTtlMinutes": 30,
      "SemanticCacheMaxEntries": 500
    },
    "PromptCache": {
      "EnablePrefixCache": true,
      "PrefixCacheTtlMinutes": 60,
      "PrefixCacheMaxEntries": 1000
    },
    "ExternalConnectors": []
  }
}
