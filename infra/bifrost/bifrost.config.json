{
  "$schema": "https://www.getbifrost.ai/schema",
  "client": {
    "drop_excess_requests": false,
    "enforce_auth_on_inference": true,
    "allow_direct_keys": true,
    "enable_logging": true,
    "allowed_origins": [
      "*"
    ]
  },
  "providers": {
    "openai": {
      "keys": [
        {
          "id": "openai-api-key",
          "name": "OpenAI API Key",
          "description": "OpenAI API Key",
          "value": "env.OPENAI_API_KEY",
          "is_active": true,
          "is_default": true,
          "weight": 1.0,
          "models": [
            "*"
          ]
        }
      ]
    }
  },
  "governance": {
    "auth_config": {
      "admin_username": "env.ADMIN_USERNAME",
      "admin_password": "env.ADMIN_PASSWORD",
      "is_enabled": true,
      "disable_auth_on_inference": false
    },
    "virtual_keys": [
      {
        "id": "vk-ryan-prod",
        "is_active": true,
        "name": "ryan-prod",
        "description": "Ryan's production virtual key",
        "value": "env.RYAN_PROD_VIRTUAL_KEY",
        "provider_configs": [
          {
            "provider": "openai",
            "allowed_models": [
              "*"
            ],
            "key_ids": [
              "*"
            ],
            "weight": 1
          }
        ]
      },
      {
        "id": "vk-ryan-work",
        "is_active": true,
        "name": "ryan-work",
        "description": "Ryan's work virtual key",
        "value": "env.RYAN_WORK_VIRTUAL_KEY",
        "provider_configs": [
          {
            "provider": "openai",
            "allowed_models": [
              "*"
            ],
            "key_ids": [
              "*"
            ],
            "weight": 1
          }
        ]
      }
    ]
  },
  "mcp": {
    "client_configs": [
      {
        "name": "local",
        "connection_type": "http",
        "client_id": "local-mcp-server",
        "tool_sync_interval": "1m",
        "connection_string": "http://mcp-server:8081/mcp",
        "auth_type": "none",
        "is_code_mode_client": true,
        "is_ping_available": true,
        "allow_on_all_virtual_keys": true,
        "tools_to_execute": [
          "*"
        ],
        "tools_to_auto_execute": [
          "list_standards",
          "read_document",
          "search_documents",
          "ingestion_status",
          "list_agents",
          "get_agent",
          "search_agents",
          "list_agent_scopes",
          "agent_status",
          "get_context",
          "scan_project",
          "memory_recall",
          "memory_read",
          "memory_status",
          "get_model_mapping",
          "list_model_mappings",
          "recommend_model",
          "list_llm_providers",
          "list_workflows",
          "get_workflow",
          "resolve_workflow_trigger",
          "list_external_connectors",
          "list_external_mcp_tools",
          "parse_openapi",
          "analyze_runtime_logs",
          "summarize_errors",
          "incident_timeline",
          "analyze_diff",
          "fetch",
          "knowledge_search",
          "knowledge_retrieve",
          "knowledge_pending",
          "knowledge_status"
        ]
      },
      {
        "name": "filesystem",
        "connection_type": "stdio",
        "client_id": "filesystem-mcp-server",
        "connection_string": "filesystem-mcp-server",
        "is_code_mode_client": true,
        "allow_on_all_virtual_keys": true,
        "stdio_config": {
          "command": "npx",
          "args": [
            "-y",
            "@modelcontextprotocol/server-filesystem"
          ]
        },
        "auth_type": "none",
        "tools_to_execute": [
          "*"
        ],
        "tools_to_auto_execute": [
          "directory_tree",
          "get_file_info",
          "list_directory",
          "list_directory_with_sizes",
          "read_file",
          "read_media_file",
          "read_multiple_files",
          "read_text_file",
          "search_files"
        ]
      }
    ]
  },
  "config_store": {
    "enabled": true,
    "type": "postgres",
    "config": {
      "host": "env.BIFROST_DB_HOST",
      "port": "env.BIFROST_DB_PORT",
      "user": "env.BIFROST_DB_USER",
      "password": "env.BIFROST_DB_PASSWORD",
      "db_name": "env.BIFROST_DB_NAME",
      "ssl_mode": "env.BIFROST_DB_SSLMODE"
    }
  },
  "logs_store": {
    "enabled": true,
    "type": "postgres",
    "config": {
      "host": "env.BIFROST_DB_HOST",
      "port": "env.BIFROST_DB_PORT",
      "user": "env.BIFROST_DB_USER",
      "password": "env.BIFROST_DB_PASSWORD",
      "db_name": "env.BIFROST_DB_NAME",
      "ssl_mode": "env.BIFROST_DB_SSLMODE"
    }
  },
  "vector_store": {
    "enabled": true,
    "type": "redis",
    "config": {
      "addr": "env.BIFROST_REDIS_ADDR"
    }
  },
  "plugins": [
    {
      "enabled": true,
      "name": "otel",
      "config": {
        "service_name": "bifrost",
        "collector_url": "https://otlp.nr-data.net:4318/v1/traces",
        "trace_type": "genai_extension",
        "protocol": "http",
        "headers": {
          "api-key": "env.NEWRELIC_API_KEY"
        },
        "metrics_enabled": true,
        "metrics_endpoint": "https://otlp.nr-data.net:4318/v1/metrics",
        "insecure": false,
        "tls_ca_cert": ""
      }
    },
    {
      "enabled": true,
      "name": "semantic_cache",
      "config": {
        "dimension": 1,
        "ttl": "5m",
        "cleanup_on_shutdown": true,
        "cache_by_model": true,
        "cache_by_provider": true
      }
    }
  ]
}
