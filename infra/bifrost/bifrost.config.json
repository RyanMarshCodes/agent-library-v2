{
  "$schema": "https://www.getbifrost.ai/schema",
  "client": {
    "drop_excess_requests": false
  },
  "providers": {},
  "governance": {
    "auth_config": {
      "admin_username": "env.ADMIN_USERNAME",
      "admin_password": "env.ADMIN_PASSWORD",
      "is_enabled": true,
      "disable_auth_on_inference": false
    },
    "virtual_keys": [
      {
        "id": "vk-ryan-prod",
        "is_active": true,
        "name": "ryan-prod",
        "description": "Ryan's production virtual key",
        "value": "env.INITIAL_VIRTUAL_KEY"
      }
    ]
  },
  "mcp": {
    "client_configs": [
      {
        "name": "ryan",
        "connection_type": "http",
        "client_id": "ryan-mcp-server",
        "connection_string": "http://localhost:8081/mcp"
      }
    ]
  },
  "config_store": {
    "enabled": true,
    "type": "postgres",
    "config": {
      "host": "env.BIFROST_DB_HOST",
      "port": "env.BIFROST_DB_PORT",
      "user": "env.BIFROST_DB_USER",
      "password": "env.BIFROST_DB_PASSWORD",
      "db_name": "env.BIFROST_DB_NAME",
      "ssl_mode": "env.BIFROST_DB_SSLMODE"
    }
  },
  "logs_store": {
    "enabled": true,
    "type": "postgres",
    "config": {
      "host": "env.BIFROST_DB_HOST",
      "port": "env.BIFROST_DB_PORT",
      "user": "env.BIFROST_DB_USER",
      "password": "env.BIFROST_DB_PASSWORD",
      "db_name": "env.BIFROST_DB_NAME",
      "ssl_mode": "env.BIFROST_DB_SSLMODE"
    }
  },
  "vector_store": {
    "enabled": true,
    "type": "redis",
    "config": {
      "addr": "env.BIFROST_REDIS_ADDR"
    }
  }
}
