{
  "$schema": "https://www.getbifrost.ai/schema",
  "client": {
    "drop_excess_requests": false
  },
  "providers": {},
  "governance": {
    "auth_config": {
      "admin_username": "env.ADMIN_USERNAME",
      "admin_password": "env.ADMIN_PASSWORD",
      "is_enabled": true,
      "disable_auth_on_inference": false
    },
    "virtual_keys": [
      {
        "id": "vk-ryan-prod",
        "is_active": true,
        "name": "ryan-prod",
        "description": "Ryan's production virtual key",
        "value": "env.INITIAL_VIRTUAL_KEY"
      }
    ]
  },
  "mcp": {
    "client_configs": [
      {
        "name": "ryan",
        "connection_type": "http",
        "client_id": "ryan-mcp-server",
        "connection_string": "http://mcp-server:8081/mcp",
        "tools_to_execute": [
          "*"
        ],
        "tools_to_auto_execute": [
          "list_standards",
          "read_document",
          "search_documents",
          "knowledge_retrieve",
          "ingestion_status",
          "knowledge_status",
          "list_agents",
          "get_agent",
          "search_agents",
          "list_agent_scopes",
          "agent_status",
          "get_context",
          "scan_project",
          "memory_recall",
          "memory_read",
          "memory_status",
          "get_model_mapping",
          "list_model_mappings",
          "recommend_model",
          "list_llm_providers",
          "list_workflows",
          "get_workflow",
          "resolve_workflow_trigger",
          "list_external_connectors",
          "list_external_mcp_tools",
          "parse_openapi",
          "analyze_runtime_logs",
          "summarize_errors",
          "incident_timeline",
          "analyze_diff",
          "fetch"
        ]
      }
    ]
  },
  "config_store": {
    "enabled": true,
    "type": "postgres",
    "config": {
      "host": "env.BIFROST_DB_HOST",
      "port": "env.BIFROST_DB_PORT",
      "user": "env.BIFROST_DB_USER",
      "password": "env.BIFROST_DB_PASSWORD",
      "db_name": "env.BIFROST_DB_NAME",
      "ssl_mode": "env.BIFROST_DB_SSLMODE"
    }
  },
  "logs_store": {
    "enabled": true,
    "type": "postgres",
    "config": {
      "host": "env.BIFROST_DB_HOST",
      "port": "env.BIFROST_DB_PORT",
      "user": "env.BIFROST_DB_USER",
      "password": "env.BIFROST_DB_PASSWORD",
      "db_name": "env.BIFROST_DB_NAME",
      "ssl_mode": "env.BIFROST_DB_SSLMODE"
    }
  },
  "vector_store": {
    "enabled": true,
    "type": "redis",
    "config": {
      "addr": "env.BIFROST_REDIS_ADDR"
    }
  }
}
