# Copy to .env in this directory:  copy .env.example .env   (PowerShell: Copy-Item .env.example .env)
# Used for compose ${VAR:-default} substitution and passed into bifrost, postgres, and redis containers.

# --- Bifrost (see https://docs.getbifrost.ai/quickstart/gateway/setting-up )
LOG_LEVEL=info
LOG_STYLE=json

# --- Postgres (docker compose --profile postgres)
POSTGRES_USER=bifrost
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bifrost
# Optional: override initdb (default in compose is UTF-8 + C.UTF-8). Needed only for a different locale/image.
# POSTGRES_INITDB_ARGS=--encoding=UTF8 --lc-collate=C.UTF-8 --lc-ctype=C.UTF-8

# --- Provider keys (optional; bifrost can read these when config references env.* )
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
