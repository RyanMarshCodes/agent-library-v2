# -----------------------------------------------------------------------------
# Shared runtime configuration for unified MCP + Bifrost stack.
#
# Default mode (no profile) is LOCAL-FIRST using dockerized postgres/redis.
# For remote managed services, override the host/credentials below and start
# only selected services if desired (see infra/mcp/README.md).
# -----------------------------------------------------------------------------

# Service ports (host)
MCP_PORT=8081
BIFROST_PORT=8080

# -----------------------------------------------------------------------------
# MCP server -> Postgres (memory DB)
# -----------------------------------------------------------------------------
MCP_PROJECT_SLUG=ryan-mcp
MCP_DB_HOST=postgres
MCP_DB_PORT=5432
MCP_DB_NAME=ryan_mcp
MCP_DB_USER=postgres
MCP_DB_PASSWORD=postgres
MCP_DB_SSLMODE=Disable
MCP_DB_COMMAND_TIMEOUT_SECONDS=30
MCP_AUTO_INGEST_ON_STARTUP=true
MCP_WATCH_FOR_CHANGES=false

# -----------------------------------------------------------------------------
# Bifrost -> Postgres (config/logs store)
# -----------------------------------------------------------------------------
BIFROST_DB_HOST=postgres
BIFROST_DB_PORT=5432
BIFROST_DB_NAME=bifrost
BIFROST_DB_USER=postgres
BIFROST_DB_PASSWORD=postgres
BIFROST_DB_SSLMODE=disable

# Bifrost -> Redis (vector/cache)
BIFROST_REDIS_ADDR=redis:6379

# Bifrost logging style
LOG_LEVEL=info
LOG_STYLE=json

# Optional provider keys used by Bifrost providers
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=

# Optional MCP remote connector credentials
# GITHUB_TOKEN=
# AZURE_DEVOPS_PAT=

# Optional OTel collector endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT=

# -----------------------------------------------------------------------------
# Local Postgres/Redis container settings.
# -----------------------------------------------------------------------------
LOCAL_POSTGRES_ADMIN_USER=postgres
LOCAL_POSTGRES_ADMIN_PASSWORD=postgres
LOCAL_POSTGRES_DEFAULT_DB=postgres
LOCAL_POSTGRES_INITDB_ARGS=--encoding=UTF8 --lc-collate=C.UTF-8 --lc-ctype=C.UTF-8
LOCAL_POSTGRES_PORT=5432
LOCAL_REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Optional remote override examples (uncomment and replace values):
# MCP_DB_HOST=<azure-postgres-host>.postgres.database.azure.com
# MCP_DB_USER=<azure-user>
# MCP_DB_PASSWORD=<azure-password>
# MCP_DB_SSLMODE=Require
# BIFROST_DB_HOST=<azure-postgres-host>.postgres.database.azure.com
# BIFROST_DB_USER=<azure-user>
# BIFROST_DB_PASSWORD=<azure-password>
# BIFROST_DB_SSLMODE=require
# BIFROST_REDIS_ADDR=<azure-redis-host>.redis.cache.windows.net:6380
