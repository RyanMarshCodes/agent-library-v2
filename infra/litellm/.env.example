# Copy to .env and fill in values. Never commit .env.
# Used by: docker compose (litellm, db, redis) and GitHub Actions deploy (LITELLM_DOTENV secret).

# --- Postgres (db service + LiteLLM Prisma) ---
POSTGRES_DB=litellm
POSTGRES_USER=llmproxy
POSTGRES_PASSWORD=

DATABASE_URL=postgresql://llmproxy:CHANGE_ME@db:5432/litellm

# --- Redis (router tpm/rpm + response cache; must match LiteLLM prod guidance) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- LiteLLM core ---
LITELLM_MASTER_KEY=
LITELLM_SALT_KEY=
STORE_MODEL_IN_DB=True

# Production: disable in-app dotenv load; Docker still injects env from env_file / compose.
LITELLM_MODE=PRODUCTION

# Logging: ERROR in prod per LiteLLM docs (reduces FastAPI noise).
LITELLM_LOG=ERROR

# Match vCPU count on the VPS (e.g. 2, 4, 8).
NUM_WORKERS=2

# Optional: recycle workers if memory grows under load (use with gunicorn mode in advanced setups).
# MAX_REQUESTS_BEFORE_RESTART=10000

# --- Slack alerting (used with general_settings.alerting: ["slack"]) ---
SLACK_WEBHOOK_URL=

# --- OpenTelemetry -> New Relic (callbacks: ["otel"] in litellm_config.yaml) ---
# LiteLLM uses these names (see https://docs.litellm.ai/docs/proxy/logging#opentelemetry):
# NR OTLP: https://docs.newrelic.com/docs/opentelemetry/best-practices/opentelemetry-otlp/
#
# Use the ACCOUNT LICENSE KEY in api-key= (Account settings), NOT a User API key (NRAK-*), or exports often return 403.
# EU accounts: https://otlp.eu01.nr-data.net:4318/v1/traces
# No quotes around OTEL_HEADERS — quotes can become part of the header value and break auth.
OTEL_SERVICE_NAME=litellm-proxy
OTEL_EXPORTER=otlp_http
OTEL_ENDPOINT=https://otlp.nr-data.net:4318/v1/traces
OTEL_HEADERS=api-key=REPLACE_WITH_LICENSE_KEY
# Optional while debugging:
# OTEL_DEBUG=True

# Optional OTEL overrides (LiteLLM defaults are fine for many setups).
# OTEL_TRACER_NAME=litellm

# --- Browser / CORS (if calling the API from a web app; nginx TLS in front) ---
# LITELLM_CORS_ORIGINS=https://your-proxy-hostname.example

# --- Provider API keys (add what you use; referenced from litellm_config model_list or Admin UI) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# CURSOR_API_KEY=
